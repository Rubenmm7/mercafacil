FROM maven:3.9-eclipse-temurin-21
WORKDIR /app

# Cache de dependencias (solo se re-descarga si cambia pom.xml)
COPY pom.xml .
RUN mvn dependency:go-offline -B

EXPOSE 8080

# Compile loop en background: recompila cada 2s los .java montados vía volumen.
# Spring DevTools detecta los .class nuevos y reinicia el contexto (~3-5s).
# exec reemplaza el shell por mvn para que Docker pueda enviarle señales correctamente.
CMD ["sh", "-c", "(while true; do sleep 2; mvn compile -q 2>/dev/null; done) & exec mvn spring-boot:run"]
