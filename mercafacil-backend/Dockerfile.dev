FROM maven:3.9-eclipse-temurin-21
WORKDIR /app

# Cache de dependencias (solo se re-descarga si cambia pom.xml)
COPY pom.xml .
RUN mvn dependency:go-offline -B

EXPOSE 8080

# Loop de fondo: recompila cada 2s los .java del host (montados vía volumen).
# Spring DevTools detecta los .class nuevos y reinicia el contexto automáticamente.
CMD ["sh", "-c", "(sleep 30 && while true; do mvn compile -q; sleep 5; done) & mvn spring-boot:run"]
